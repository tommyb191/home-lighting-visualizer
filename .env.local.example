# Copy to .env.local for local dev. In production these live in Vercel →
# Settings → Environment Variables (never commit real values).

# Google Gemini image generation (aistudio.google.com)
GEMINI_API_KEY=paste_your_gemini_key_here

# Resend transactional email (resend.com)
RESEND_API_KEY=paste_your_resend_key_here

# Where lead notifications are sent
BUSINESS_EMAIL=you@yourcompany.com

# "From" address — must use a Resend-verified domain
# (before verification, use onboarding@resend.dev)
FROM_EMAIL=preview@yourcompany.com

# "From" name on outgoing email
BUSINESS_NAME=Phantom

# "Start a project" link target
BUSINESS_WEBSITE=https://phantomsound.com/start-a-project/

# ── Nextdoor conversion tracking ───────────────────────────────────────────
# Pixel ID from Nextdoor Ads Manager → Assets > Pixels ("Data Source ID").
# PUBLIC — inlined into the browser bundle (NEXT_PUBLIC_ prefix). Also reused
# server-side as the CAPI "data_source_id" that dedupes pixel + server events.
# Leave blank to disable tracking entirely (e.g. local dev).
NEXT_PUBLIC_NEXTDOOR_PIXEL_ID=7a6dfc84-84eb-464e-8458-64ac0e55b0b7

# Server-side Conversions API (CAPI) bearer token (Ads Manager → API settings,
# OAuth 2.0, expires yearly). SERVER-ONLY — never commit, never expose to the
# browser. Optional: if blank, the server-side Lead is skipped cleanly and the
# client pixel still tracks.
NEXTDOOR_CAPI_TOKEN=paste_your_nextdoor_capi_token_here
